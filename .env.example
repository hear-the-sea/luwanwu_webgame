# ============================================================================
# Django Core Settings
# ============================================================================

# SECRET_KEY: REQUIRED in production
# For development: Use the fixed key below for consistent sessions across restarts
# For production: Generate a new secure key with:
#   python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
# WARNING: Never use the development key in production!
DJANGO_SECRET_KEY=django-insecure-dev-only-key-do-not-use-in-production-abc123xyz789

# DEBUG: Set to 1 for development, 0 for production (DEFAULT: 0 for security)
# WARNING: Never set DEBUG=1 in production!
DJANGO_DEBUG=0

# ALLOWED_HOSTS: Comma-separated list of allowed hosts (NEVER use * in production)
# Example: example.com,www.example.com
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# ============================================================================
# Game Time Configuration
# ============================================================================

# 全局时间流速倍率：1=正常，100=所有计时类行为加速100倍（升级/出征/生产/训练等）
# 注意：倍率过大可能导致大量倒计时任务在很短时间内完成，从而显著增加 Celery/Redis/DB 负载；生产环境建议保持为 1
GAME_TIME_MULTIPLIER=1

# PVP：目标24小时被攻击次数的短缓存TTL（秒）
# 更小值=更实时但查询更频繁；更大值=查询更少但统计显示略滞后。事务内关键校验会绕过缓存。
DJANGO_RAID_RECENT_ATTACKS_CACHE_TTL_SECONDS=5

# ============================================================================
# Security Settings (Production)
# ============================================================================

# CSRF Trusted Origins: Comma-separated list of trusted origins for CSRF
# Example: https://example.com,https://www.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# SSL/HTTPS Configuration
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SECURE_HSTS_SECONDS=31536000

# Reverse proxy trust settings
# Enable only when running behind a trusted reverse proxy and set proxy IPs.
# Example: DJANGO_TRUSTED_PROXY_IPS=127.0.0.1,172.16.0.0/12
DJANGO_USE_PROXY=0
DJANGO_TRUSTED_PROXY_IPS=
DJANGO_ACCESS_LOG_TRUST_PROXY=0

# File Upload Limits (in bytes)
DJANGO_FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
DJANGO_DATA_UPLOAD_MAX_MEMORY_SIZE=10485760

# ============================================================================
# Database Configuration
# ============================================================================

DJANGO_DB_ENGINE=django.db.backends.mysql
DJANGO_DB_NAME=webgame
DJANGO_DB_USER=root
DJANGO_DB_PASSWORD=your-database-password-here
DJANGO_DB_HOST=127.0.0.1
DJANGO_DB_PORT=3306

# Database Connection Pooling
# CONN_MAX_AGE: Persistent connection lifetime in seconds
#   - 0 = disabled (new connection per request, not recommended)
#   - 60 = development default (60 seconds)
#   - 300-600 = production recommended (5-10 minutes)
#   - None = never close connections (for PgBouncer/external pooling)
# DJANGO_DB_CONN_MAX_AGE=300

# CONN_HEALTH_CHECKS: Check connection health before reuse (recommended: 1)
# DJANGO_DB_CONN_HEALTH_CHECKS=1

# PostgreSQL-specific settings (ignored by SQLite/MySQL)
# SSL Mode: require (production) | prefer (development) | disable
# DJANGO_DB_SSLMODE=prefer

# DISABLE_SERVER_SIDE_CURSORS: Required when using PgBouncer in transaction mode
# Set to 1 if using PgBouncer, leave unset otherwise
# DJANGO_DB_DISABLE_SERVER_SIDE_CURSORS=0

# Performance Notes:
# - For development (SQLite): Default settings are fine
# - For production with PostgreSQL directly: Set CONN_MAX_AGE=300-600
# - For production with PgBouncer: Set CONN_MAX_AGE=None, DISABLE_SERVER_SIDE_CURSORS=1
# - For Celery workers: Consider shorter CONN_MAX_AGE (60-120) to avoid connection buildup

# ============================================================================
# Redis Configuration
# ============================================================================

REDIS_URL=redis://127.0.0.1:6379
REDIS_CHANNEL_URL=redis://127.0.0.1:6379/1
REDIS_BROKER_URL=redis://127.0.0.1:6379/0
REDIS_RESULT_URL=redis://127.0.0.1:6379/0
REDIS_CACHE_URL=redis://127.0.0.1:6379/2

# ============================================================================
# Celery Configuration
# ============================================================================

CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
CELERY_DEFAULT_QUEUE=default
CELERY_BATTLE_QUEUE=battle
CELERY_TIMER_QUEUE=timer
