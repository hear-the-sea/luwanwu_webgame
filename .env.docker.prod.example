# Docker Compose production environment example
#
# Usage:
#   cp .env.docker.prod.example .env.docker
#   docker compose -f docker-compose.prod.yml up -d --build

DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com
DJANGO_SECRET_KEY=please-change-me-in-production
DJANGO_USE_PROXY=1
# Set to your reverse-proxy IP(s) or CIDR(s), comma-separated.
# For Docker bridge networks, a common starting point is 172.16.0.0/12.
DJANGO_TRUSTED_PROXY_IPS=172.16.0.0/12
DJANGO_ACCESS_LOG_TRUST_PROXY=1

# If TLS terminates at a reverse proxy/load balancer in front of the app,
# keep this as 1 (recommended). If you are serving plain HTTP only, set it to 0.
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SECURE_HSTS_SECONDS=31536000

# Database (MySQL in docker-compose.prod.yml)
MYSQL_PASSWORD=change-me-strong-db-password
MYSQL_ROOT_PASSWORD=change-me-strong-root-password

DJANGO_DB_ENGINE=django.db.backends.mysql
DJANGO_DB_NAME=webgame
DJANGO_DB_USER=webgame
DJANGO_DB_PASSWORD=change-me-strong-db-password
DJANGO_DB_HOST=db
DJANGO_DB_PORT=3306

# Redis (docker-compose.prod.yml)
REDIS_URL=redis://redis:6379
REDIS_CHANNEL_URL=redis://redis:6379/1
REDIS_BROKER_URL=redis://redis:6379/0
REDIS_RESULT_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/2

# Optional: enable Redis AUTH
REDIS_PASSWORD=

# If Redis requires auth, you may set REDIS_PASSWORD (preferred) or embed it in the URL.
# Example (URL form):
# REDIS_URL=redis://:change-me-redis-password@redis:6379

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Startup behavior
DJANGO_RUN_MIGRATIONS=0
DJANGO_SYNC_GUEST_TEMPLATES=1
DJANGO_GUEST_TEMPLATES_FILE=data/guest_templates.yaml
DJANGO_GUEST_HEROES_DIR=data/guests
DJANGO_GUEST_TEMPLATES_SKIP_IMAGES=0
DJANGO_COLLECTSTATIC=1
DJANGO_STATIC_USE_MANIFEST=1
DJANGO_WAIT_FOR_DB_SECONDS=60
DJANGO_WAIT_FOR_REDIS_SECONDS=60

# Observability
DJANGO_ACCESS_LOG=1

# App image tag loaded by `docker load`
WEBGAME_IMAGE=webgame:v1
