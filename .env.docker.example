# Docker Compose development environment example
#
# Usage:
#   cp .env.docker.example .env.docker
#   docker compose up --build

DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SECRET_KEY=please-change-me-in-docker
DJANGO_USE_PROXY=0
DJANGO_STATIC_USE_MANIFEST=0
DJANGO_SYNC_GUEST_TEMPLATES=0
DJANGO_GUEST_TEMPLATES_FILE=data/guest_templates.yaml
DJANGO_GUEST_HEROES_DIR=data/guests
DJANGO_GUEST_TEMPLATES_SKIP_IMAGES=1
DJANGO_TRUSTED_PROXY_IPS=
DJANGO_ACCESS_LOG_TRUST_PROXY=0

# Database (MySQL in docker-compose.yml)
DJANGO_DB_ENGINE=django.db.backends.mysql
DJANGO_DB_NAME=webgame
DJANGO_DB_USER=webgame
DJANGO_DB_PASSWORD=xxxxxx
DJANGO_DB_HOST=db
DJANGO_DB_PORT=3306

# Redis (docker-compose.yml)
REDIS_URL=redis://redis:6379
REDIS_CHANNEL_URL=redis://redis:6379/1
REDIS_BROKER_URL=redis://redis:6379/0
REDIS_RESULT_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/2

# Optional: enable Redis AUTH (recommended if you expose Redis beyond the docker network)
# If set, docker-compose.yml will start Redis with --requirepass and services should use REDIS_PASSWORD.
REDIS_PASSWORD=

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_DEFAULT_QUEUE=default
CELERY_BATTLE_QUEUE=battle
CELERY_TIMER_QUEUE=timer

# Optional: make startup waits longer on slower machines
DJANGO_WAIT_FOR_DB_SECONDS=60
DJANGO_WAIT_FOR_REDIS_SECONDS=60
