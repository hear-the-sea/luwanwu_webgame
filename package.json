{
  "name": "web-game-v5",
  "version": "1.0.0",
  "description": "春秋乱世庄园主 - 古风武侠游戏",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./static/css/tailwind.css",
    "watch:css": "tailwindcss -i ./src/input.css -o ./static/css/tailwind.css --watch",
    "build:css:prod": "tailwindcss -i ./src/input.css -o ./static/css/tailwind.css --minify",
    "test:js": "node --test static/js/tests/chat_widget_*.test.js"
  },
  "devDependencies": {
    "tailwindcss": "^4.2.2",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.16"
  }
}
